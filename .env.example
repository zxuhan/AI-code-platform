# ========================================
# ai-code — .env (used by docker-compose only; native runs read application-local.yml instead)
# ========================================
# Copy this file to .env and fill in real values.
# Anything you don't set here uses the default shown above each line.
#
# IMPORTANT: docker compose's .env parser does NOT support inline comments.
# Comments must be on their own line. NEVER write `KEY=value # comment`
# — the `# comment` portion gets parsed as part of the value and breaks things.
# ========================================


# ---------- Required (compose refuses to start without this) ----------
GEMINI_API_KEY=


# ---------- Required on droplet only (must match folio's value) ----------
# Default: 123456
# MYSQL_ROOT_PASSWORD=


# ---------- Cloudflare R2 (screenshot/upload endpoints fail silently without these) ----------
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Format: https://pub-<hash>.r2.dev or your custom domain
R2_PUBLIC_URL=


# ---------- Optional overrides (defaults are fine for personal use) ----------
# Default: gemini-2.5-flash-lite (used for routing, cheap)
# GEMINI_TEXT_MODEL=

# Default: gemini-2.5-flash (used for HTML / multi-file streaming)
# GEMINI_STREAMING_MODEL=

# Default: gemini-2.5-pro (used for the tool-calling Vue agent)
# Set this plus GEMINI_REASONING_MAX_OUTPUT_TOKENS=8192 if you want flash everywhere.
# GEMINI_REASONING_MODEL=

# Default: 32768 (safe for gemini-2.5-pro). Drop to 8192 when using a flash model.
# GEMINI_REASONING_MAX_OUTPUT_TOKENS=

# Default: empty (no auth — fine when Redis is on docker network only)
# REDIS_PASSWORD=

# Default: ai_code (Mac dev only; droplet uses folio's mysql with database "ai_code")
# MYSQL_DATABASE=

# Default: 8124 (host port for the backend; bound to 127.0.0.1 only)
# BACKEND_PORT=

# Default: 8082 (host port for the frontend; bound to 127.0.0.1 only — Caddy/nginx fronts it)
# FRONTEND_PORT=

# JVM tuning. Default: -Xms256m -Xmx768m -XX:+UseG1GC -XX:MaxGCPauseMillis=200
# JAVA_OPTS=

# Default: Europe/Amsterdam
# TZ=
